name: Update Repo Cards
on:
  schedule:
    - cron: '0 0 * * *'   # 매일 1회
  workflow_dispatch:        # 수동 실행 버튼
permissions:
  contents: write
jobs:
  update:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Generate repo cards
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          USER=KSNAM97
          # 최근 업데이트순으로 public 리포 가져오기 (fork 제외)
          REPOS=$(gh api "users/$USER/repos?sort=updated&per_page=100" \
            --jq '.[] | select(.fork==false) | .name')

          CARDS=""
          for repo in $REPOS; do
            CARDS="${CARDS}[![${repo}](https://github-readme-stats.vercel.app/api/pin/?username=${USER}&repo=${repo}&theme=github_dark)](https://github.com/${USER}/${repo})\n"
          done

          # 마커 사이를 교체
          python3 - <<EOF
          import re
          with open("README.md","r",encoding="utf-8") as f:
              c = f.read()
          cards = "$(printf '%b' "$CARDS")"
          c = re.sub(r"<!-- REPO-LIST:START -->.*<!-- REPO-LIST:END -->",
                     "<!-- REPO-LIST:START -->\n"+cards+"<!-- REPO-LIST:END -->",
                     c, flags=re.DOTALL)
          with open("README.md","w",encoding="utf-8") as f:
              f.write(c)
          EOF
      - name: Commit
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add README.md
          git commit -m "chore: auto-update repo cards" || echo "no changes"
          git push
